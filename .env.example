DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-app.onrender.com,yourusername.pythonanywhere.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com,https://yourusername.pythonanywhere.com

# Optional deployment settings
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000

# Optional SQLite override for hosts that need a custom writable path
SQLITE_PATH=

# Optional email settings for contact form notifications
DEFAULT_FROM_EMAIL=
CONTACT_NOTIFICATION_EMAIL=